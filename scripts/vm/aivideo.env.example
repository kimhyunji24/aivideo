# /etc/aivideo/aivideo.env 예시
# 실제 운영 시 파일 권한을 600으로 두고 민감정보를 입력하세요.

SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8080
FRONTEND_PORT=3000
JAVA_OPTS=-Xms256m -Xmx1024m

# Backend
VERTEX_PROJECT_ID=your-gcp-project-id
GEMINI_LOCATION=asia-northeast1
GOOGLE_APPLICATION_CREDENTIALS=/home/hyunji/.config/gcloud/application_default_credentials.json
VEO_STORAGE_URI=gs://your-bucket
